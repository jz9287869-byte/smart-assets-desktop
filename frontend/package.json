{
  "name": "smart-image-library-ui",
  "version": "1.0.0",
  "private": true,
  "homepage": ".",
  "dependencies": {
    "lucide-react": "^0.309.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-scripts": "5.0.1",
    "react-window": "^1.8.10"
  },
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",
    "test": "react-scripts test",
    "test:ci": "cross-env CI=true react-scripts test --watchAll=false",
    "start:ci": "cross-env BROWSER=none react-scripts start",
    "lint": "cross-env CI=true react-scripts build",
    "format": "prettier --write \"src/**/*.{js,jsx,json,css,md}\" \"public/**/*.html\"",
    "format:check": "prettier --check \"src/**/*.{js,jsx,json,css,md}\" \"public/**/*.html\"",
    "lighthouse:ci": "node scripts/lighthouse.js",
    "eject": "react-scripts eject"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.4.2",
    "@testing-library/react": "^14.2.1",
    "@testing-library/user-event": "^14.5.2",
    "autoprefixer": "^10.4.27",
    "chrome-launcher": "^1.2.0",
    "cross-env": "^7.0.3",
    "lighthouse": "^12.8.2",
    "postcss": "^8.5.8",
    "prettier": "^3.6.2",
    "tailwindcss": "^3.4.17"
  }
}
